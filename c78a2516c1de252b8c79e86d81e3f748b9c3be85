    {
      "unresolved": false,
      "key": {
        "uuid": "bc1715fa_6cdf996c",
        "filename": "/PATCHSET_LEVEL",
        "patchSetId": 1
      },
      "lineNbr": 0,
      "author": {
        "id": 1002622
      },
      "writtenOn": "2026-06-22T06:19:49Z",
      "side": 1,
      "message": "In phosphor-networkd, interfaces listed in the IGNORED_INTERFACES\n environment variable are not exposed as DBus objects, and therefore\n will not appear in Redfish or WebUI.\n These interfaces may still require runtime IP configuration for\n BMC communication, even though external management\n is not needed.",
      "parentUuid": "d0181ebf_7133e497",
      "revId": "c78a2516c1de252b8c79e86d81e3f748b9c3be85",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
    {
